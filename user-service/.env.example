# Application
APP_ENV=local

# HTTP Server
HTTP_ADDR=:8081
SHUTDOWN_TIMEOUT=10s

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=user_service
MONGO_TIMEOUT=10s

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=accounts.events
KAFKA_GROUP_ID=user-service
KAFKA_ENABLED=true

# Logging
LOG_LEVEL=info
