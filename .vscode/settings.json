{
  "gopls": {
    "ui.completion.usePlaceholders": false,
    "analysis.staticcheck": false,
    "ui.diagnostic.analyses": {
      "shadow": false,
      "unusedparams": false
    }
  },
  "go.buildOnSave": "off",
  "go.vetOnSave": "off",
  "go.lintOnSave": "off",
  "files.watcherExclude": {
    "**/vendor/**": true,
    "**/.git/**": true
  }
}