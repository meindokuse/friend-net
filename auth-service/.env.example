# Application
APP_ENV=local

# Server
HTTP_ADDR=:8080
SHUTDOWN_TIMEOUT=10s

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=auth_service_new
POSTGRES_SSL_MODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_DB=0

# JWT
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-key-must-be-at-least-32-characters-long
JWT_ISSUER=auth-service-new
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_GRACE_PERIOD=30s

# Password hashing
PASS_COST=10

# Controller
COOKIE_DOMAIN=
COOKIE_SECURE=false
REFRESH_COOKIE_NAME=refresh_token

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Kafka (optional)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=accounts.events
KAFKA_CONSUMER_GROUP=auth-service-new-flusher

# Outbox Flusher
OUTBOX_FLUSH_ENABLED=true
OUTBOX_FLUSH_INTERVAL=5s
OUTBOX_BATCH_SIZE=100
OUTBOX_LOCK_TIMEOUT=30s
OUTBOX_RETRY_ATTEMPTS=3
OUTBOX_RETRY_DELAY=1s

# Graceful shutdown
GRACEFUL_TIMEOUT=10s
